{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "SEMGREP_FRAGMENT_URL=https://mcp-dev.semgrep.ai/fragment ${CLAUDE_PLUGIN_ROOT}/scripts/run-semgrep.py scan"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "semgrep mcp -k inject-secure-defaults"
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check_version.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "semgrep mcp -k inject-secure-defaults-short"
          }
        ]
      }
    ]
  }
}
