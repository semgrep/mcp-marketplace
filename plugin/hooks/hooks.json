{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "SEMGREP_FRAGMENT_URL=https://mcp-dev.semgrep.ai/fragment ${CLAUDE_PLUGIN_ROOT}/scripts/run-semgrep.py scan"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/login.py",
            "async": true,
            "timeout": 180
          }
        ]
      }
    ]
  }
}
